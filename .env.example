# ─── Database (Neon free tier) ───────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/yourkalinga?sslmode=require

# ─── Auth (custom JWT) ───────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Groq (AI Recommendation — free tier) ────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ─── Video (Jitsi Meet — open source) ────────────────────
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
NEXT_PUBLIC_JITSI_ROOM_PREFIX=yourkalinga-

# ─── File Storage (Cloudinary free tier) ─────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=YourKalinga
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
